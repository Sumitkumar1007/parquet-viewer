APP_NAME=Parquet Query Studio
APP_ENV=development
SECRET_KEY=change-this-to-strong-random-secret
ADMIN_USERNAME=admin
# Create with: python3 -c "from app.core.auth import hash_password; print(hash_password('ChangeMe123!'))"
ADMIN_PASSWORD_HASH=
PARQUET_PATH=./data/sample.parquet
PARQUET_ROOT=./data
HDFS_BASE_PATH=hdfs://10.20.30.6:9000/hdfs/data/sftp
SESSION_TTL_MINUTES=480
MAX_PREVIEW_ROWS=200
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=500
MAX_UPLOAD_MB=25
ALLOW_RECURSIVE_SCAN=false
USERS_FILE=./runtime/users.json
AUDIT_LOG_PATH=./runtime/audit.log
